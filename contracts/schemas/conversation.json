{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Conversation",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "user_id": {
      "type": "string",
      "format": "uuid"
    },
    "title": {
      "type": "string"
    },
    "model_tag": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "id",
    "user_id",
    "title",
    "model_tag",
    "created_at",
    "updated_at"
  ]
}
