# Nanochat Default Configuration
#
# This file contains default settings for nanochat experiments.
# Copy this to local/.env and customize for your setup.

# ============================================================================
# Environment Setup
# ============================================================================

# Base directory for data, checkpoints, and models
# Set this to your local directory or project root
NANOCHAT_BASE_DIR=/path/to/nanochat/local

# Compute dtype (auto-detected by default)
# Options: bfloat16, float32, float16
# NANOCHAT_DTYPE=bfloat16

# ============================================================================
# WandB Configuration
# ============================================================================

# WandB project name
WANDB_PROJECT=nanochat

# WandB entity (your username or team)
# WANDB_ENTITY=your-username

# WandB API key (get from https://wandb.ai/authorize)
# WANDB_API_KEY=your-api-key

# ============================================================================
# Hardware Configuration
# ============================================================================

# Number of GPUs to use
NPROC_PER_NODE=8

# Device type (auto-detected by default)
# Options: cuda, cpu, mps
# DEVICE_TYPE=cuda

# ============================================================================
# Training Defaults
# ============================================================================

# Model depth (12=GPT-1, 24=GPT-2, 32=GPT-3 scale)
DEFAULT_DEPTH=12

# Batch size per device
DEFAULT_DEVICE_BATCH_SIZE=32

# Total batch size (auto-computed if -1)
DEFAULT_TOTAL_BATCH_SIZE=-1

# Number of training iterations
DEFAULT_NUM_ITERATIONS=2000

# Evaluation frequency
DEFAULT_EVAL_EVERY=250

# CORE metric evaluation frequency (-1 to disable)
DEFAULT_CORE_METRIC_EVERY=-1

# Sampling frequency (-1 to disable)
DEFAULT_SAMPLE_EVERY=-1

# Checkpoint save frequency (-1 to save only at end)
DEFAULT_SAVE_EVERY=-1

# ============================================================================
# Compression Metrics Configuration
# ============================================================================

# Enable compression tracking by default
DEFAULT_TRACK_COMPRESSION=true

# Log compression metrics every N steps
DEFAULT_COMPRESSION_LOG_EVERY=100

# Track per-layer compression (slower)
DEFAULT_TRACK_LAYER_COMPRESSION=false

# Enable compression-based early stopping
DEFAULT_COMPRESSION_EARLY_STOP=false

# ============================================================================
# Data Configuration
# ============================================================================

# Number of data shards to download
# 8 = quick test (~10GB)
# 100 = medium scale (~120GB)
# 1000 = full dataset (~1.2TB)
DEFAULT_DATA_SHARDS=8

# Tokenizer vocabulary size
DEFAULT_VOCAB_SIZE=32768

# Maximum characters for tokenizer training
DEFAULT_TOK_MAX_CHARS=2000000000

# ============================================================================
# Experiment Naming
# ============================================================================

# Default run name prefix
DEFAULT_RUN_PREFIX=exp

# Model tag (checkpoint directory name)
# DEFAULT_MODEL_TAG=my-model

# ============================================================================
# Paths (relative to NANOCHAT_BASE_DIR)
# ============================================================================

# Data directory
DATA_DIR=data

# Checkpoint directories
BASE_CHECKPOINTS_DIR=base_checkpoints
MID_CHECKPOINTS_DIR=mid_checkpoints
SFT_CHECKPOINTS_DIR=sft_checkpoints
RL_CHECKPOINTS_DIR=rl_checkpoints

# Tokenizer path
TOKENIZER_PATH=tok32768.model

# ============================================================================
# Advanced Settings
# ============================================================================

# FP8 training (requires H100+ GPU)
DEFAULT_FP8=false

# FP8 recipe (tensorwise or rowwise)
DEFAULT_FP8_RECIPE=tensorwise

# Window pattern for sliding window attention
DEFAULT_WINDOW_PATTERN=SSSL

# Learning rates
DEFAULT_EMBEDDING_LR=0.3
DEFAULT_UNEMBEDDING_LR=0.008
DEFAULT_MATRIX_LR=0.02
DEFAULT_SCALAR_LR=0.5
DEFAULT_WEIGHT_DECAY=0.28

# LR schedule
DEFAULT_WARMUP_STEPS=40
DEFAULT_WARMDOWN_RATIO=0.65
DEFAULT_FINAL_LR_FRAC=0.05

# ============================================================================
# Notes
# ============================================================================

# To use this config:
# 1. Copy to local/.env: cp dev/config.default local/.env
# 2. Edit local/.env with your settings
# 3. Source it: source local/.env
# 4. Or use direnv: echo "dotenv local/.env" > .envrc && direnv allow
